#!/bin/sh

set -e

case "$1" in
    configure|triggered)
        if [ -x /usr/local/sbin/openhd-rk3566-bookworm-splash-setup ]; then
            /usr/local/sbin/openhd-rk3566-bookworm-splash-setup || true
        fi

        # The X20 package carries the legacy launcher. Preserve the platform
        # markers consumed by OpenHD's X20 and RTL8812AU detection paths.
        if [ -x /usr/local/bin/x20/OpenHD_X20 ]; then
            mkdir -p /usr/local/share/openhd_platform/x20
            mkdir -p /usr/local/share/openhd_platform/wifi_card_type/88xxau
            touch /usr/local/share/openhd_platform/x20/hdzero
            touch /usr/local/share/openhd_platform/wifi_card_type/88xxau/custom
        fi

        # X20 images use SysV init. Registering the script also works safely on
        # systemd hosts, where the native unit with the same name takes priority.
        if [ -x /etc/init.d/openhd-sys-utils ]; then
            if command -v update-rc.d >/dev/null 2>&1; then
                update-rc.d openhd-sys-utils defaults
            fi

            if command -v invoke-rc.d >/dev/null 2>&1; then
                invoke-rc.d openhd-sys-utils start || true
            elif [ ! -d /run/systemd/system ]; then
                /etc/init.d/openhd-sys-utils start || true
            fi
        fi
        ;;
esac

exit 0
